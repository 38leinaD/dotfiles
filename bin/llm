#!/usr/bin/env bash

# `llm` — wrapper compatible with a subset of Simon Willison's `llm` CLI
# (https://llm.datasette.io), dispatching to one of:
#   - Claude Code CLI (`claude`)
#   - GitHub Copilot CLI (`copilot`)
#
# Backend detection: claude if installed, otherwise copilot.
#
# Supported flags:
#   -m, --model <alias>       Model alias: sonnet|opus|haiku|gpt5|auto
#                             Errors out if the alias is unavailable on the
#                             selected backend.
#   -s, --system <text>       System prompt. claude: --append-system-prompt.
#                             copilot: prepended as SYSTEM/USER section in the
#                             user prompt (no native flag).
#   -c, --continue            Continue the most recent conversation
#                             (claude --continue / copilot --resume).
#   -t, --template <name>     Load template from
#                             ~/.config/llm-sh/templates/<name>; `$input` in
#                             the template is replaced with args+stdin.
#   -x, --extract             Print only the first fenced code block from the
#                             response.
#       --xl                  Print only the last fenced code block.
#       --schema <file>       Constrain output to JSON matching the schema in
#                             <file>. claude: native --json-schema. copilot:
#                             prompt-injection plus `jq -e` validation.
#   -d, --debug               Print backend/model/system/user prompt to stderr
#                             before calling.
#       --dry-run             Like --debug, but exit without calling the LLM.
#   -q, --quiet               Suppress the stderr progress spinner. Useful
#                             when a caller (e.g. gcm) shows its own progress
#                             indicator. Auto-suppressed when stderr is not a
#                             TTY.
#   -h, --help                Show this help.
#
# Stdin semantics (matches `llm`):
#   prompt = args + "\n\n" + stdin
#   With -t/--template, the combined input replaces `$input` in the template.
#
# Environment:
#   LLM_SH_TEMPLATES   Override the template directory.
#                      Default: ~/.config/llm-sh/templates
#
# Usage examples
#
#   One-shot prompt:
#     llm "explain quantum tunneling in one paragraph"
#
#   Pipe content with an instruction (args first, stdin appended):
#     cat error.log | llm "what is the root cause here?"
#     git diff --cached | llm "write a one-line commit message"
#
#   Pick a model with an alias:
#     llm -m opus "design a database schema for a todo app"
#     llm -m gpt5 "review this Python: $(< foo.py)"
#     llm -m haiku "TL;DR of:" < article.md
#
#   System prompt:
#     llm -s "answer in one sentence" "what is RAII?"
#     cat code.py | llm -s "you are a strict code reviewer" "review this"
#
#   Continue the previous conversation:
#     llm "summarise the SOLID principles"
#     llm -c "now give me one Python example for each"
#
#   Templates (place files in ~/.config/llm-sh/templates/<name>):
#     # ~/.config/llm-sh/templates/commit-msg contains:
#     #   Write a concise, one-line git commit message for this diff:
#     #
#     #   $input
#     git diff --cached | llm -t commit-msg
#
#   Extract first/last fenced code block (for piping into a shell or file):
#     llm -x "bash one-liner: count unique IPs in access.log" | sh
#     llm -x "convert this YAML to JSON" < config.yaml > config.json
#     llm --xl "write code with explanation, then final answer last" > out
#
#   Structured JSON output via schema:
#     echo '{"type":"object","properties":{"name":{"type":"string"},
#            "age":{"type":"integer"}},"required":["name","age"]}' > person.json
#     llm --schema person.json "Jane is 32 years old"
#
#   Debug what is sent to the backend:
#     llm -d "test prompt"          # print + still call
#     llm --dry-run "test prompt"   # print + exit, no tokens spent
#
#   Suppress the spinner when a caller renders its own progress:
#     llm --quiet "..."             # silent on stderr
#
# Exit codes:
#   0  success
#   1  no backend CLI (claude, copilot) installed
#   2  unknown flag, or empty prompt (no args, no stdin, no template)
#   3  template file not found
#   4  schema file not found
#   5  model alias not available on the active backend
#   6  --schema set but copilot response is not valid JSON

set -euo pipefail

print_help() {
    sed -n '3,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//' | head -n -1
}

# ---------- argument parsing ----------

SYSTEM=""
MODEL_ALIAS=""
CONTINUE=0
EXTRACT=""        # "" | "first" | "last"
SCHEMA_FILE=""
TEMPLATE=""
DEBUG=0
DRY_RUN=0
QUIET=0
POSITIONAL=()

while [ $# -gt 0 ]; do
    case "$1" in
        -m|--model)      MODEL_ALIAS="${2:-}"; shift 2 ;;
        -s|--system)     SYSTEM="${2:-}"; shift 2 ;;
        -c|--continue)   CONTINUE=1; shift ;;
        -t|--template)   TEMPLATE="${2:-}"; shift 2 ;;
        -x|--extract)    EXTRACT="first"; shift ;;
        --xl)            EXTRACT="last"; shift ;;
        --schema)        SCHEMA_FILE="${2:-}"; shift 2 ;;
        -d|--debug)      DEBUG=1; shift ;;
        --dry-run)       DRY_RUN=1; shift ;;
        -q|--quiet)      QUIET=1; shift ;;
        -h|--help)       print_help; exit 0 ;;
        --)              shift; while [ $# -gt 0 ]; do POSITIONAL+=("$1"); shift; done ;;
        -*)              echo "llm: unknown flag: $1" >&2; exit 2 ;;
        *)               POSITIONAL+=("$1"); shift ;;
    esac
done

ARGS="${POSITIONAL[*]:-}"

# ---------- read stdin ----------

STDIN=""
if [ ! -t 0 ]; then
    STDIN=$(cat)
fi

# Combine args + stdin into the input that fills `$input` in templates,
# or becomes the prompt directly. Args come first so the instruction is
# read before the (often longer) piped content.
if [ -n "$ARGS" ] && [ -n "$STDIN" ]; then
    INPUT="$ARGS"$'\n\n'"$STDIN"
elif [ -n "$STDIN" ]; then
    INPUT="$STDIN"
else
    INPUT="$ARGS"
fi

# ---------- template ----------

if [ -n "$TEMPLATE" ]; then
    TPL_DIR="${LLM_SH_TEMPLATES:-$HOME/.config/llm-sh/templates}"
    TPL_PATH="$TPL_DIR/$TEMPLATE"
    if [ ! -f "$TPL_PATH" ]; then
        echo "llm: template not found: $TPL_PATH" >&2
        exit 3
    fi
    # Substitute literal `$input` with the combined input. Use awk so the
    # replacement is treated as data — the input may contain backticks,
    # $VAR, backslashes, etc., that would break shell-eval substitution.
    PROMPT=$(awk -v input="$INPUT" '
        {
            n = index($0, "$input")
            while (n > 0) {
                $0 = substr($0, 1, n-1) input substr($0, n+6)
                n = index($0, "$input")
            }
            print
        }
    ' "$TPL_PATH")
else
    PROMPT="$INPUT"
fi

if [ -z "$PROMPT" ]; then
    echo "llm: empty prompt (no args, no stdin, no template)" >&2
    exit 2
fi

# ---------- schema ----------

SCHEMA_JSON=""
if [ -n "$SCHEMA_FILE" ]; then
    if [ ! -f "$SCHEMA_FILE" ]; then
        echo "llm: schema file not found: $SCHEMA_FILE" >&2
        exit 4
    fi
    SCHEMA_JSON=$(cat "$SCHEMA_FILE")
fi

# ---------- backend detection ----------

if command -v claude >/dev/null 2>&1; then
    BACKEND="claude"
elif command -v copilot >/dev/null 2>&1; then
    BACKEND="copilot"
else
    echo "llm: no supported AI CLI found." >&2
    echo "  install one of:" >&2
    echo "    Claude Code CLI:    https://docs.anthropic.com" >&2
    echo "    GitHub Copilot CLI: https://docs.github.com/en/copilot/concepts/agents/about-copilot-cli" >&2
    exit 1
fi

# ---------- model alias resolution ----------
# Maps the wrapper's short aliases to the model name each backend expects.
# Update these strings if the upstream CLIs rename their models.

resolve_model() {
    local alias="$1"
    case "$BACKEND:$alias" in
        claude:sonnet)   echo "sonnet" ;;
        claude:opus)     echo "opus" ;;
        claude:haiku)    echo "haiku" ;;
        claude:gpt5)     echo "__NOT_AVAILABLE__" ;;
        claude:auto)     echo "__NOT_AVAILABLE__" ;;
        copilot:sonnet)  echo "claude-sonnet-4.5" ;;
        copilot:gpt5)    echo "gpt-5" ;;
        copilot:auto)    echo "auto" ;;
        copilot:opus)    echo "__NOT_AVAILABLE__" ;;
        copilot:haiku)   echo "__NOT_AVAILABLE__" ;;
        *)               echo "$alias" ;;  # pass through unknown aliases
    esac
}

RESOLVED_MODEL=""
if [ -n "$MODEL_ALIAS" ]; then
    RESOLVED_MODEL=$(resolve_model "$MODEL_ALIAS")
    if [ "$RESOLVED_MODEL" = "__NOT_AVAILABLE__" ]; then
        echo "llm: model alias '$MODEL_ALIAS' is not available via $BACKEND" >&2
        exit 5
    fi
fi

# ---------- assemble final system prompt ----------

FINAL_SYSTEM="$SYSTEM"

if [ -n "$SCHEMA_JSON" ] && [ "$BACKEND" = "copilot" ]; then
    SCHEMA_INSTRUCTION="Respond ONLY with a single JSON document that strictly conforms to this JSON schema. Output the JSON only — no markdown code fences, no commentary.

Schema:
$SCHEMA_JSON"
    if [ -n "$FINAL_SYSTEM" ]; then
        FINAL_SYSTEM="$FINAL_SYSTEM"$'\n\n'"$SCHEMA_INSTRUCTION"
    else
        FINAL_SYSTEM="$SCHEMA_INSTRUCTION"
    fi
fi

# For copilot, fold the system prompt into the user prompt as a SYSTEM
# section, since copilot CLI has no system-prompt flag.
COPILOT_PROMPT="$PROMPT"
if [ "$BACKEND" = "copilot" ] && [ -n "$FINAL_SYSTEM" ]; then
    COPILOT_PROMPT="SYSTEM:
$FINAL_SYSTEM

USER:
$PROMPT"
fi

# ---------- debug / dry-run ----------

if [ "$DEBUG" -eq 1 ] || [ "$DRY_RUN" -eq 1 ]; then
    {
        echo "--- llm-sh debug ---"
        echo "backend:  $BACKEND"
        echo "model:    ${RESOLVED_MODEL:-<default>}"
        echo "continue: $([ "$CONTINUE" -eq 1 ] && echo yes || echo no)"
        echo "extract:  ${EXTRACT:-no}"
        echo "template: ${TEMPLATE:-<none>}"
        echo "schema:   ${SCHEMA_FILE:-<none>}"
        echo "--- SYSTEM ---"
        printf '%s\n' "$FINAL_SYSTEM"
        echo "--- USER ---"
        if [ "$BACKEND" = "copilot" ]; then
            printf '%s\n' "$COPILOT_PROMPT"
        else
            printf '%s\n' "$PROMPT"
        fi
        echo "---"
    } >&2
fi

if [ "$DRY_RUN" -eq 1 ]; then
    exit 0
fi

# ---------- run backend ----------

run_claude() {
    local args=(-p)
    [ -n "$RESOLVED_MODEL" ] && args+=(--model "$RESOLVED_MODEL")
    [ -n "$FINAL_SYSTEM" ]   && args+=(--append-system-prompt "$FINAL_SYSTEM")
    [ "$CONTINUE" -eq 1 ]    && args+=(--continue)
    if [ -n "$SCHEMA_JSON" ]; then
        args+=(--json-schema "$SCHEMA_JSON" --output-format json)
    fi
    args+=("$PROMPT")
    claude "${args[@]}"
}

run_copilot() {
    local disabled_mcps=()
    if [ -f "$HOME/.copilot/mcp-config.json" ]; then
        while IFS= read -r line; do
            [ -n "$line" ] && read -ra parts <<< "$line" && disabled_mcps+=("${parts[@]}")
        done < <(jq -r '.mcpServers // {} | to_entries[] | select(.value.disabled == true) | "--disable-mcp-server \(.key)"' "$HOME/.copilot/mcp-config.json" 2>/dev/null || true)
    fi
    local args=()
    [ ${#disabled_mcps[@]} -gt 0 ] && args+=("${disabled_mcps[@]}")
    args+=(-s)
    [ -n "$RESOLVED_MODEL" ] && args+=(--model "$RESOLVED_MODEL")
    [ "$CONTINUE" -eq 1 ]    && args+=(--resume)
    args+=(-p "$COPILOT_PROMPT")
    copilot "${args[@]}"
}

# ---------- progress spinner ----------
# Same braille rotation as the ai-command helper in shell/.functions, on
# stderr. Skipped when --quiet is set or stderr is not a TTY (so capturing
# stderr to a file or piping to a logger doesn't pollute output).

SPINNER_PID=""

start_spinner() {
    [ "$QUIET" -eq 1 ] && return
    [ -t 2 ] || return
    (
        local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
        local i=0
        while :; do
            printf '\r\033[2K%s thinking…' "${frames[i % 10]}" >&2
            sleep 0.1
            i=$((i + 1))
        done
    ) &
    SPINNER_PID=$!
    disown "$SPINNER_PID" 2>/dev/null || true
}

stop_spinner() {
    if [ -n "$SPINNER_PID" ]; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        printf '\r\033[2K' >&2
        SPINNER_PID=""
    fi
}

trap stop_spinner EXIT INT TERM

# When the spinner is on we always capture output (otherwise the spinner
# would interleave with streamed tokens). Post-processing (extract / schema)
# already implies capture.

NEEDS_CAPTURE=0
[ -n "$EXTRACT" ]                                          && NEEDS_CAPTURE=1
[ -n "$SCHEMA_JSON" ]                                      && NEEDS_CAPTURE=1
[ "$QUIET" -eq 0 ] && [ -t 2 ]                             && NEEDS_CAPTURE=1

if [ "$NEEDS_CAPTURE" -eq 0 ]; then
    if [ "$BACKEND" = "claude" ]; then
        run_claude
    else
        run_copilot
    fi
    exit 0
fi

start_spinner
if [ "$BACKEND" = "claude" ]; then
    RESPONSE=$(run_claude)
else
    RESPONSE=$(run_copilot)
fi
stop_spinner

# claude's --output-format=json wraps the answer in a JSON envelope; unwrap.
if [ -n "$SCHEMA_JSON" ] && [ "$BACKEND" = "claude" ]; then
    RESPONSE=$(printf '%s' "$RESPONSE" | jq -r '.result // .')
fi

# copilot schema validation (best-effort, no retry).
if [ -n "$SCHEMA_JSON" ] && [ "$BACKEND" = "copilot" ]; then
    if ! printf '%s' "$RESPONSE" | jq -e . >/dev/null 2>&1; then
        echo "llm: copilot response is not valid JSON" >&2
        printf '%s\n' "$RESPONSE" >&2
        exit 6
    fi
fi

# Extract first/last fenced code block.
if [ -n "$EXTRACT" ]; then
    RESPONSE=$(printf '%s' "$RESPONSE" | awk -v which="$EXTRACT" '
        BEGIN { in_block = 0; buf = ""; saved = "" }
        /^```/ {
            if (in_block) {
                in_block = 0
                if (which == "first") { printf "%s", buf; exit }
                saved = buf
                buf = ""
            } else {
                in_block = 1
                buf = ""
            }
            next
        }
        in_block { buf = buf $0 ORS }
        END {
            if (which == "last") { printf "%s", saved }
        }
    ')
fi

printf '%s\n' "$RESPONSE"
