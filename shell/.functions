#!/usr/bin/env bash

j() {
	java $@
}

async() {
	local cmd="$1"
 	shift
  	"$cmd" "$@" > /dev/null 2>&1 &
}

tmuxdev() {
    tmux new-session -d -s dev -n dev
    tmux new-window -t dev: -n misc
    tmux new-window -t dev: -n man
    tmux attach-session -t dev:dev
}

war() {
  # is "--" present as its own arg?
	idx=${argv[(I)--]}

	if (( idx )); then
		# split argv around the "--"
		watchlist=("${argv[1,$((idx-1))]}")     # args before --
		command=("${argv[$((idx+1)),-1]}")      # args after  --
	else
		# no "--": last arg is the watch target, the rest is the command
		watchlist=("${argv[-1]}")
		command=("${argv[1,-1]}")
	fi

	echo "watchlist:: <$watchlist>"
	echo "command:: <$command>"
	wad_do() {
		clear;
		the_time=$(date +%H:%M:%S)
		start=$(date +%s.%N)
		# Run the command that was provided as argument
		eval $@;
		rc=$?
		end=$(date +%s.%N)
		diff=$(echo "${end} - ${start}" | bc)
		if [ $rc -eq 0 ]; then
			echo ""
			echo -e "\e[2m[${the_time}]\e[0m \e[1;32m** Successful **\e[0m \e[2m(time: ${diff} seconds)\e[0m"
		else
			echo ""
			echo -e "\e[2m[${the_time}]\e[0m \e[1;31m** Failed **\e[0m"
		fi
		sleep 1;
	}
	wad_do $command
	while inotifywait --recursive -qq  --include "$watchlist" .; do
		wad_do $command
	done
}

co() {
    local disabled_mcps=$(jq -r '.mcpServers | to_entries[] | select(.value.disabled == true) | "--disable-mcp-server \(.key)"' ~/.copilot/mcp-config.json 2>/dev/null | tr '\n' ' ')
    eval "copilot --yolo $disabled_mcps $@"
}

# -----------------------------------------------------------------------------
# AI-powered Git Commit Function
# Copy paste this gist into your ~/.bashrc or ~/.zshrc to gain the `gcm` command. It:
# 1) gets the current staged changed diff
# 2) sends them to an LLM to write the git commit message
# 3) allows you to easily accept, edit, regenerate, cancel
# But - just read and edit the code however you like
# the `llm` CLI util is awesome, can get it here: https://llm.datasette.io/en/stable/
unalias gcm 2>/dev/null
gcm() {
    # Function to generate commit message
    generate_commit_message() {
        git diff --cached | llm --quiet "
Below is a diff of all staged changes, coming from the command:
\`\`\`
git diff --cached
\`\`\`
Please generate a concise, one-line commit message for these changes."
    }

    # Function to read user input compatibly with both Bash and Zsh
    read_input() {
        if [ -n "$ZSH_VERSION" ]; then
            echo -n "$1"
            read -r REPLY
        else
            read -p "$1" -r REPLY
        fi
    }

    # Main script
    echo "Generating AI-powered commit message..."
    commit_message=$(generate_commit_message)

    while true; do
        echo -e "\nProposed commit message:"
        echo "$commit_message"

        read_input "Do you want to (a)ccept, (e)dit, (r)egenerate, or (c)ancel? "
        choice=$REPLY

        case "$choice" in
            a|A )
                if git commit -m "$commit_message"; then
                    echo "Changes committed successfully!"
                    return 0
                else
                    echo "Commit failed. Please check your changes and try again."
                    return 1
                fi
                ;;
            e|E )
                read_input "Enter your commit message: "
                commit_message=$REPLY
                if [ -n "$commit_message" ] && git commit -m "$commit_message"; then
                    echo "Changes committed successfully with your message!"
                    return 0
                else
                    echo "Commit failed. Please check your message and try again."
                    return 1
                fi
                ;;
            r|R )
                echo "Regenerating commit message..."
                commit_message=$(generate_commit_message)
                ;;
            c|C )
                echo "Commit cancelled."
                return 1
                ;;
            * )
                echo "Invalid choice. Please try again."
                ;;
        esac
    done
}


# AI shell command generator
ai-command() {
  emulate -L zsh
  setopt local_options no_monitor no_notify

  local instruction="$BUFFER"

  if [[ -z "$instruction" ]]; then
    zle redisplay
    return
  fi

  local tmpfile=$(mktemp)
  llm --quiet "You are a zshell expert. Convert this instruction into command that runs in zshell. Only output the command, no explanation, no markdown code block.

Instruction:
$instruction" > "$tmpfile" 2>/dev/null &
  local pid=$!

  local spinner=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=1
  while kill -0 $pid 2>/dev/null; do
    zle -M "${spinner[$((i % 10 + 1))]} Generating command..."
    zle -R
    sleep 0.1
    ((i++))
  done
  wait $pid

  local cmd=$(<"$tmpfile")
  rm -f "$tmpfile"

  BUFFER="$cmd"
  CURSOR=${#BUFFER}
  zle -M ""
  zle redisplay
}

zle -N ai-command
bindkey '^G' ai-command   # Ctrl+G
